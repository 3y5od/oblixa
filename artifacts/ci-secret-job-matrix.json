{
  "_documentation": "Maps repo Actions secrets (ci.yml top-level env) to jobs that actually require them. Fork PRs may have empty secrets — jobs must gate with explicit skip steps, not undefined behavior.",
  "secrets": [
    {
      "name": "E2E_ONBOARDING_FULL",
      "envVar": "E2E_ONBOARDING_FULL",
      "requiredByJobs": ["quality_e2e_onboarding_full"]
    },
    {
      "name": "E2E_TEST_EMAIL",
      "envVar": "E2E_TEST_EMAIL",
      "requiredByJobs": ["quality_build_e2e", "quality_e2e_onboarding_full"]
    },
    {
      "name": "E2E_TEST_PASSWORD",
      "envVar": "E2E_TEST_PASSWORD",
      "requiredByJobs": ["quality_build_e2e", "quality_e2e_onboarding_full"]
    },
    {
      "name": "STAGING_BASE_URL",
      "envVar": "STAGING_BASE_URL",
      "requiredByJobs": ["runtime_comprehensive_pass"]
    },
    {
      "name": "CRON_SECRET",
      "envVar": "CRON_SECRET",
      "requiredByJobs": ["runtime_comprehensive_pass"]
    },
    {
      "name": "SUPABASE_SERVICE_ROLE_KEY",
      "envVar": "SUPABASE_SERVICE_ROLE_KEY",
      "requiredByJobs": ["runtime_comprehensive_pass"]
    },
    {
      "name": "NEXT_PUBLIC_SUPABASE_URL",
      "envVar": "NEXT_PUBLIC_SUPABASE_URL",
      "requiredByJobs": ["runtime_comprehensive_pass"]
    },
    {
      "name": "NEXT_PUBLIC_SUPABASE_ANON_KEY",
      "envVar": "NEXT_PUBLIC_SUPABASE_ANON_KEY",
      "requiredByJobs": ["runtime_comprehensive_pass"]
    },
    {
      "name": "COMPREHENSIVE_PASS_EMAIL",
      "envVar": "COMPREHENSIVE_PASS_EMAIL",
      "requiredByJobs": ["runtime_comprehensive_pass"]
    },
    {
      "name": "COMPREHENSIVE_PASS_PASSWORD",
      "envVar": "COMPREHENSIVE_PASS_PASSWORD",
      "requiredByJobs": ["runtime_comprehensive_pass"]
    },
    {
      "name": "HC_RUNTIME_COMPREHENSIVE_PING",
      "envVar": "HC_RUNTIME_COMPREHENSIVE_PING",
      "requiredByJobs": ["runtime_comprehensive_pass"],
      "optional": true
    }
  ]
}
