{
  "version": 3,
  "helperScript": "scripts/github-actions/secret-gate.sh",
  "workflows": {
    "ci.yml": {
      "gates": [
        {
          "job": "quality_build_e2e",
          "requiredSecrets": ["E2E_TEST_EMAIL", "E2E_TEST_PASSWORD"],
          "defaultBehavior": "skip",
          "strictVariable": "REQUIRE_CI_E2E_AUTH"
        },
        {
          "job": "quality_e2e_onboarding_full",
          "requiredSecrets": ["E2E_ONBOARDING_FULL"],
          "defaultBehavior": "skip",
          "strictVariable": "REQUIRE_CI_ONBOARDING_FULL",
          "optionalName": true
        },
        {
          "job": "quality_e2e_onboarding_full",
          "requiredSecrets": ["E2E_TEST_EMAIL", "E2E_TEST_PASSWORD"],
          "defaultBehavior": "skip",
          "strictVariable": "REQUIRE_CI_E2E_AUTH"
        },
        {
          "job": "runtime_comprehensive_pass",
          "requiredSecrets": [
            "STAGING_BASE_URL",
            "CRON_SECRET",
            "SUPABASE_SERVICE_ROLE_KEY",
            "NEXT_PUBLIC_SUPABASE_URL",
            "NEXT_PUBLIC_SUPABASE_ANON_KEY",
            "COMPREHENSIVE_PASS_EMAIL",
            "COMPREHENSIVE_PASS_PASSWORD"
          ],
          "defaultBehavior": "skip",
          "strictVariable": "REQUIRE_RUNTIME_COMPREHENSIVE"
        }
      ]
    },
    "codeql.yml": { "kind": "standard" },
    "cron-canary.yml": {
      "gates": [
        {
          "job": "canary",
          "requiredSecrets": ["STAGING_BASE_URL", "CRON_SECRET"],
          "defaultBehavior": "skip",
          "strictVariable": "REQUIRE_CRON_CANARY"
        }
      ]
    },
    "dependency-review.yml": { "kind": "standard" },
    "load-smoke-optional.yml": {
      "gates": [
        {
          "job": "load_smoke",
          "requiredSecrets": ["STAGING_BASE_URL"],
          "defaultBehavior": "skip",
          "strictVariable": "REQUIRE_LOAD_SMOKE",
          "optionalName": true
        }
      ]
    },
    "openssf-scorecard.yml": { "kind": "standard" },
    "pr-process-stub.yml": { "kind": "standard" },
    "qa-android-webview.yml": { "kind": "standard" },
    "qa-cdn-purge.yml": { "kind": "standard" },
    "qa-code-maximal.yml": {
      "kind": "standard",
      "scheduledSecretUsage": [
        {
          "job": "staging_optional_matrix",
          "allowedEvents": ["schedule", "workflow_dispatch"],
          "requiredSecrets": [
            "RLS_SMOKE_STRICT",
            "SUPABASE_SERVICE_ROLE_KEY",
            "STAGING_BASE_URL",
            "SLO_BUDGETS_STRICT"
          ],
          "reason": "Scheduled staging smoke matrix uses optional staging and Supabase secrets only in selected matrix legs."
        }
      ]
    },
    "qa-dast-zap.yml": { "kind": "standard" },
    "qa-debugging-sweep.yml": { "kind": "standard" },
    "qa-external-stubs.yml": { "kind": "standard" },
    "qa-game-day.yml": { "kind": "standard" },
    "qa-helm-lint.yml": { "kind": "standard" },
    "qa-ios-wkwebview.yml": { "kind": "standard" },
    "qa-ipv6-smoke.yml": { "kind": "standard" },
    "qa-k8s-smoke.yml": { "kind": "standard" },
    "qa-macos-a11y-optional.yml": { "kind": "standard" },
    "qa-max-nightly.yml": {
      "kind": "standard",
      "scheduledSecretUsage": [
        {
          "job": "qa_static",
          "allowedEvents": ["schedule", "workflow_dispatch"],
          "requiredSecrets": [
            "STAGING_BASE_URL",
            "RLS_SMOKE_STRICT",
            "RUN_LIGHTHOUSE_NIGHTLY",
            "SYNTHETIC_STRICT",
            "SEMGREP_FULL",
            "SBOM_DIFF_STRICT",
            "DOMAIN_STRICT",
            "DNSSEC_PRIVACY_STRICT",
            "CERT_STRICT",
            "READABILITY_STRICT",
            "EMAIL_DNS_STRICT",
            "COSIGN_PUBLIC_KEY",
            "SLSA_VERIFY_STRICT",
            "DR_DRILL_STRICT",
            "SUPPLY_CHAIN_STUB_REPORT",
            "CARBON_RUNTIME_REPORT",
            "K8S_POLICY_STRICT",
            "REPORT_GATE_STRICT",
            "POSTMERGE_VERIFY_STRICT"
          ],
          "reason": "Scheduled QA ultimate passes an explicit optional secret map to the reusable workflow instead of using secrets: inherit."
        },
        {
          "job": "api_runtime_smoke_nightly",
          "allowedEvents": ["schedule"],
          "requiredSecrets": ["STAGING_BASE_URL"],
          "reason": "Nightly API runtime smoke probes the configured staging base URL when present."
        }
      ]
    },
    "qa-merge-queue-canary.yml": { "kind": "standard" },
    "qa-ofac-hash-verify.yml": { "kind": "standard" },
    "qa-post-merge-smoke.yml": { "kind": "standard" },
    "qa-release-candidate.yml": { "kind": "standard" },
    "qa-secrets-history-scan-optional.yml": { "kind": "standard" },
    "qa-secrets-rotation-drill.yml": { "kind": "standard" },
    "qa-stryker-monthly.yml": { "kind": "standard" },
    "qa-taxonomy-closure.yml": { "kind": "standard" },
    "qa-terraform-plan.yml": { "kind": "standard" },
    "qa-visual-update.yml": { "kind": "standard" },
    "qa-windows-edge-optional.yml": { "kind": "standard" },
    "refinement-deletion-notice.yml": { "kind": "standard" },
    "reusable-qa-ultimate.yml": { "kind": "standard" },
    "secretlint-optional.yml": { "kind": "standard" },
    "security-audit-weekly.yml": { "kind": "standard" },
    "semgrep-sarif.yml": { "kind": "standard" },
    "slo-monitor.yml": {
      "gates": [
        {
          "job": "monitor",
          "requiredSecrets": ["NEXT_PUBLIC_SUPABASE_URL", "SUPABASE_SERVICE_ROLE_KEY", "HC_SLO_MONITOR_PING"],
          "defaultBehavior": "skip",
          "strictVariable": "REQUIRE_SLO_MONITOR"
        }
      ]
    },
    "trivy-fs.yml": { "kind": "standard" }
  }
}
