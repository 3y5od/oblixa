{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oblixa.local/schemas/assurance-waivers.schema.json",
  "title": "Assurance waivers (Epic 12)",
  "type": "object",
  "required": ["version", "waivers"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "waivers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "owner", "expiresOn", "reason", "scope"],
        "properties": {
          "id": { "type": "string", "minLength": 3 },
          "owner": { "type": "string", "minLength": 2 },
          "expiresOn": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
          "reason": { "type": "string", "minLength": 8 },
          "scope": { "type": "string", "minLength": 2 },
          "relatedEpicTodoKey": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
