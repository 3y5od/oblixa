# See https://help.github.com/articles/ignoring-files/

# Dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js
.next/
out/

# Production / output
build/
dist/

# Testing & coverage
coverage/
cyclonedx-sbom.json
test-results/
playwright-report/
blob-report/
playwright/.cache/

# Vercel / Turborepo
.vercel
.turbo

# TypeScript
*.tsbuildinfo

# ESLint / Prettier (local caches)
.eslintcache
.prettiercache

# Debug logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment (never commit secrets)
.env*
!.env.example

# TLS / keys
*.pem

# OS
.DS_Store
Thumbs.db

# Editors & temp files
# Cursor: keep shared rules in-repo; ignore local editor/workspace state
.cursor/*
!.cursor/rules/
!.cursor/rules/**
.idea/
*.swp
*.swo
*~

# Sentry CLI (may contain auth)
.sentryclirc

# Supabase CLI (local state)
supabase/.branches
supabase/.temp

# Sentry Config File
.env.sentry-build-plugin
logs.zip
logs_*.zip
