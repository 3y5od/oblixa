# =============================================================================
# Oblixa — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in real values.
#   cp .env.example .env.local
#
# NEXT_PUBLIC_ vars are embedded in the browser bundle — never put secrets there.
# All other vars are server-only.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
# Project Settings → API in the Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — NEVER prefix with NEXT_PUBLIC_
# Used for admin operations that bypass Row Level Security
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Autonomous perf driver (npm run perf:autonomous)
# -----------------------------------------------------------------------------
# PERF_TIER=A|B|C|D|E|F (default A). Optional: RUN_ANALYZE=1 RUN_K6=1 RUN_LIGHTHOUSE=1 RUN_E2E_PERF=1 RUN_STRYKER=1 RUN_TIER_F=1
# PERF_TIER=A
# PERF_SKIP_BUILD=1
# BASE_URL= or PLAYWRIGHT_BASE_URL= for lighthouse tier

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
# Developers → API keys in the Stripe dashboard
# Use test-mode keys (pk_test_ / sk_test_) during development
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# Recurring price id used for checkout sessions
STRIPE_PRICE_ID=

# Developers → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------
# API Keys page in the Resend dashboard
RESEND_API_KEY=

# Verified sender address (use onboarding@resend.dev for sandbox testing)
EMAIL_FROM=

# -----------------------------------------------------------------------------
# AI / LLM extraction pipeline
# -----------------------------------------------------------------------------
# Provider API key for schema-constrained extraction (e.g. OpenAI)
OPENAI_API_KEY=

# Optional: override chat model (default gpt-4o-mini)
# OPENAI_EXTRACTION_MODEL=gpt-4o-mini

# Optional: set to "false" if structured JSON schema calls fail for your model/account
# OPENAI_EXTRACTION_JSON_SCHEMA=false

# Optional: use a stronger model for multi-chunk contracts (after the first chunk)
# OPENAI_EXTRACTION_MODEL_LONG=gpt-4o-mini

# Optional: parallel OpenAI chunk requests for very long contracts (integer 1–8, default 3)
# EXTRACTION_CHUNK_CONCURRENCY=3

# Optional: scanned-PDF fallback (PDF uploaded to OpenAI; primary then fallback model)
# OPENAI_PDF_OCR_MODEL=gpt-4o-mini
# OPENAI_PDF_OCR_FALLBACK_MODEL=gpt-4o

# Optional: run extraction in a separate server invocation (POST /api/extract/run).
# Set the same secret in production. If unset, extraction runs inline via after().
# EXTRACTION_WORKER_SECRET=

# Optional: public origin for worker fetch when the incoming request URL is not suitable (origin only, no path).
# Example: https://your-production-domain.com
# In production, only https is allowed. Localhost, private IPs, and metadata-style hosts are rejected (falls back to request origin).
# EXTRACTION_WORKER_BASE_URL=

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# Base URL fallback when Host headers are unavailable (CLI, some cron contexts).
# Server Actions and Route Handlers prefer the incoming request Host (correct on Vercel previews).
# Vercel also sets VERCEL_URL (no scheme) — resolveAppBaseUrl uses it after Host headers.
# Local: http://localhost:3000  Production: https://oblixa.io
# Trailing slashes are optional (the app normalizes them).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional — self-hosted production behind TLS (not Vercel): emit Strict-Transport-Security from next.config headers
# OBLIXA_SELF_HOSTED_HSTS=1

# Optional — production fail-soft audit: when 1 with NODE_ENV=production, startup warns if core automation secrets are unset
# OBLIXA_STRICT_ENV=1

# Optional — build-time nonce for Content-Security-Policy-Report-Only strict script-src (staged; see src/lib/security/csp-builders.ts)
# OBLIXA_CSP_REPORT_ONLY_SCRIPT_NONCE=

# Optional — append require-trusted-types-for 'script' to report-only CSP only (staged; see next.config.ts)
# OBLIXA_TRUSTED_TYPES_REPORT_ONLY=1

# Optional — build-time: enforce strict style-src (no unsafe-inline) on main CSP in production only
# OBLIXA_CSP_STRICT_ENFORCING_STYLE=1

# -----------------------------------------------------------------------------
# Optional — operator kill-switches (503 JSON on matching subsystems; all use value 1)
# OBLIXA_KILL_SIGNUP=1
# OBLIXA_KILL_BILLING=1
# OBLIXA_KILL_EXTRACTION=1
# OBLIXA_KILL_INVITES=1
# OBLIXA_KILL_INBOUND_AUTOMATION=1
# OBLIXA_KILL_WEBHOOK_DISPATCH=1

# Step-up cookie signing secret (min 16 chars). Prefer a dedicated secret in production.
# OBLIXA_STEP_UP_SECRET=

# Optional Slack request signing for POST /api/tasks/from-slack (in addition to inbound bearer)
# SLACK_SIGNING_SECRET=

# Optional HMAC over raw JSON body for POST /api/tasks/from-email (header X-Oblixa-Email-Signature: sha256=<hex>)
# EMAIL_INBOUND_HMAC_SECRET=

# DSR: authenticated JSON self-export (default on; set 0 to disable)
# OBLIXA_DSR_SELF_EXPORT=0

# DSR: dangerous account delete hook — enable only with runbook + operator approval
# OBLIXA_DSR_ACCOUNT_DELETE=1

# -----------------------------------------------------------------------------
# Optional — debugging sweep catalog / internal diagnostics (server-only)
# -----------------------------------------------------------------------------
# Enable GET /api/internal/debugging-sweep (still requires bearer secret below).
# OBLIXA_DEBUGGING_SWEEP_ENDPOINT=1
# Bearer secret for internal diagnostics (rotate independently from CRON_SECRET).
# OBLIXA_INTERNAL_DIAG_SECRET=
# Comma-separated exact IPs and/or IPv4 CIDRs; if set, requests must match (fail closed on parse errors).
# OBLIXA_INTERNAL_DIAG_IP_ALLOWLIST=
# Optional org UUID: successful debugging-sweep calls also write v10 audit_events under this org (system actor).
# OBLIXA_INTERNAL_DIAG_AUDIT_ORG_ID=
# Optional mTLS client verification is EXT at the edge; terminate TLS upstream and forward verified client identity.
# Verbose noop sweep stub registration logs.
# OBLIXA_SWEEP_STUB_VERBOSE=1
# Node process-level diagnostic hooks (unhandledRejection logs when verbose).
# OBLIXA_PROCESS_DIAGNOSTICS=1
# CI: require artifactsPath/configPath rows to resolve to readable JSON on disk.
# OBLIXA_STRICT_ARTIFACTS=1
# CI: reject suspicious provenance title substrings.
# OBLIXA_PROVENANCE_TITLE_SCAN=1
# Optional: allow validate script to fetch referenceUrls (not used by default).
# OBLIXA_PROVENANCE_FETCH_REFS=1
# Client-only opt-in Sentry breadcrumb bridge (embedded in browser bundle when used).
# NEXT_PUBLIC_OBLIXA_CLIENT_SWEEP_BREADCRUMB=1
# Playwright: fixed x-correlation-id for log join (optional).
# PLAYWRIGHT_CORRELATION_ID=

# Optional — Google Search Console site verification token (root layout metadata)
# GOOGLE_SITE_VERIFICATION=

# -----------------------------------------------------------------------------
# Optional — product behavior
# -----------------------------------------------------------------------------
# When true, creating/editing contracts, uploads, extraction, and field review
# require an org with stripe_subscription_id set (after successful checkout).
# Leave unset or false for local development without billing.
# REQUIRE_ACTIVE_SUBSCRIPTION=true

# When true, org admins can run “Load demo contracts” in Settings (sample data).
# ENABLE_DEMO_SEED=true

# -----------------------------------------------------------------------------
# Optional — V9 Core UX (NEXT_PUBLIC_* — embedded in the browser bundle)
# -----------------------------------------------------------------------------
# Inline work / renewal row actions. Default on when unset. Set to 0 to hide affordances.
# NEXT_PUBLIC_V9_INLINE_QUEUE_ACTIONS=

# -----------------------------------------------------------------------------
# Optional — V3/V4 module toggles (env names kept for compatibility)
# -----------------------------------------------------------------------------
# Default: enabled when unset or empty. Set to false, 0, no, or off to disable.
# ENABLE_V3_TASKS_ENGINE=true
# ENABLE_V3_OBLIGATIONS_EXECUTION=true
# ENABLE_V3_APPROVALS_SLA=true
# ENABLE_V3_RENEWAL_WORKSPACE=true
# ENABLE_V3_INTAKE_PIPELINE=true
# ENABLE_V3_PERSONA_DASHBOARDS=true
# ENABLE_V3_REPORTING_HISTORY=true
# ENABLE_V3_AUTOMATION_EXPANSION=true

# -----------------------------------------------------------------------------
# Optional — V5 control plane (default: enabled when unset or empty)
# -----------------------------------------------------------------------------
# Set to false, 0, no, or off to disable each phase independently.
# ENABLE_V5_DECISION_FOUNDATION=true
# ENABLE_V5_PORTFOLIO_CAMPAIGNS=true
# ENABLE_V5_SIMULATION_AND_INTELLIGENCE=true
# ENABLE_V5_RELATIONSHIP_LAYER=true
# ENABLE_V5_EXTERNAL_COLLABORATION=true
# ENABLE_V5_CONTROL_ROOM_UX=true
# -----------------------------------------------------------------------------
# Optional - V6 assurance and adaptive execution (default: enabled when unset)
# -----------------------------------------------------------------------------
# ENABLE_V6_ASSURANCE_CORE=true
# ENABLE_V6_CONTROL_POLICIES=true
# ENABLE_V6_ADAPTIVE_PLAYBOOKS=true
# ENABLE_V6_AUTOPILOT=true
# When false, scheduled/manual autopilot will not mutate data (dry-runs still work). Default on when unset.
# ENABLE_V6_AUTOPILOT_ALLOW_EXECUTION=true
# ENABLE_V6_OUTCOME_INTELLIGENCE=true
# ENABLE_V6_REVIEW_BOARDS=true
# ENABLE_V6_SEGMENTS=true
# Decision packet PDF generation is enabled when V5 decision foundation is enabled.
# Optional: private Supabase Storage bucket for packet artifacts (JSON + PDF) uploaded by
# POST /api/decisions/[id]/packet; GET .../packet-runs/[runId]?signed=1 supports `artifact=json|pdf`.
# Create the bucket in the Supabase dashboard.
# V5_DECISION_PACKET_BUCKET=decision-packets
# Optional: separate secret for external submit tickets (defaults to passcode pepper / CRON_SECRET)
# EXTERNAL_ACTION_SUBMIT_TICKET_SECRET=
# Optional pepper for external action link passcodes (defaults to CRON_SECRET when unset in dev only).
# EXTERNAL_ACTION_PASSCODE_PEPPER=
# Production (VERCEL=1 or NODE_ENV=production): set at least one of the above or CRON_SECRET;
# the app throws at runtime if all are missing (no dev fallback).

# Secret for cron routes (GET). Use Authorization: Bearer <CRON_SECRET> or header x-cron-secret.
# Treat like a root credential: rotate rarely, never expose to clients or browser bundles.
#
# Legacy: /api/reminders/send, /api/reports/send-summaries, /api/reports/capture-metrics,
#   /api/webhooks/dispatch, /api/tasks/run-rules, /api/contracts/recompute-signals,
#   /api/integrations/calendar/sync, /api/integrations/crm/sync, /api/integrations/refresh-tokens,
#   /api/notifications/retry-deliveries, /api/maintenance/prune-operational-data
# Stripe idempotency cleanup: /api/cron/stripe-webhook-events
# V4: /api/cron/v4/exceptions-detect, /api/cron/v4/attestations-issue, /api/cron/v4/approvals-sla,
#   /api/cron/v4/escalations-dispatch, /api/cron/v4/report-packs-generate, /api/cron/v4/evidence-followup,
#   /api/cron/v4/programs-reconcile, /api/cron/v4/renewals-recompute-signals
# V5: /api/cron/v5/campaign-progress, /api/cron/v5/simulation-snapshots,
#   /api/cron/v5/capacity-forecast-refresh, /api/cron/v5/portfolio-risk-recompute,
#   /api/cron/v5/external-followup, /api/cron/v5/decision-sla-monitor,
#   /api/cron/v5/recommendation-refresh, /api/cron/v5/relationship-rollups
# V6: /api/cron/v6/assurance-checks, /api/cron/v6/finding-refresh,
#   /api/cron/v6/autopilot-dry-run, /api/cron/v6/autopilot-execution,
#   /api/cron/v6/scorecard-recompute, /api/cron/v6/health-graph-rollups,
#   /api/cron/v6/control-policy-reevaluation, /api/cron/v6/outcome-effectiveness,
#   /api/cron/v6/review-board-packet-generation, /api/cron/v6/segment-recompute
# Deploy schedules live in vercel.json; CI runs `npm run check:vercel-cron` so paths cannot drift from route handlers / canary key lists.
# CRON_SECRET=

# Optional token for inbound task integrations (Slack/email) and CRM-style callbacks
# Expected as Authorization: Bearer <token> for:
# - POST /api/tasks/from-slack
# - POST /api/tasks/from-email
# - POST /api/integrations/actions/callback
# Shared secret (all three routes when per-route vars below are unset):
# INBOUND_AUTOMATION_TOKEN=
# Optional: least-privilege overrides (each falls back to INBOUND_AUTOMATION_TOKEN):
# INBOUND_EMAIL_AUTOMATION_TOKEN=
# INBOUND_SLACK_AUTOMATION_TOKEN=
# INBOUND_INTEGRATIONS_CALLBACK_TOKEN=

# Optional: comma-separated organization UUIDs. When set, inbound routes above reject
# any other organizationId (403). Recommended for multi-tenant or shared-token setups.
# INBOUND_AUTOMATION_ORG_ALLOWLIST=

# Required for encrypting integration OAuth tokens at rest (base64-encoded 32 bytes).
# Generate: node -e "console.log(require('node:crypto').randomBytes(32).toString('base64'))"
# INTEGRATION_TOKEN_ENCRYPTION_KEY=

# Optional OAuth provider configuration (recommended via env over DB config_json).
# Names use uppercase provider ID, e.g. SLACK / GOOGLE_CALENDAR / OUTLOOK_CALENDAR / EMAIL / CRM.
# OAUTH_SLACK_AUTHORIZE_URL=
# OAUTH_SLACK_TOKEN_URL=
# OAUTH_SLACK_CLIENT_ID=
# OAUTH_SLACK_CLIENT_SECRET=
# OAUTH_SLACK_SCOPE=

# Optional: POST this URL after a successful cron run (e.g. Better Stack, healthchecks.io).
# JSON body includes sent, candidates, route.
# CRON_HEALTHCHECK_URL=

# Optional operational data retention windows (days).
# Used by /api/maintenance/prune-operational-data cron.
# OPS_RETENTION_NOTIFICATION_DELIVERIES_DAYS=120
# OPS_RETENTION_AUDIT_EVENTS_DAYS=180

# Runtime comprehensive pass checks.
# COMPREHENSIVE_PASS_BASE_URL=http://localhost:3000
# Optional: when the primary URL returns a non-401 (e.g. deployment error HTML), probe this URL next for the unsigned cron guard.
# COMPREHENSIVE_PASS_SECONDARY_BASE_URL=http://127.0.0.1:3000
# COMPREHENSIVE_PASS_EMAIL=
# COMPREHENSIVE_PASS_PASSWORD=

# Optional — set to "1" to show support-oriented diagnostics on V10 recoverability surfaces in production
# (otherwise diagnostics are dev-only). See src/components/ui/v10-recoverable-state.tsx.
# NEXT_PUBLIC_V10_SUPPORT_DIAGNOSTICS=

# Optional — distributed rate limits (Upstash Redis). Without these, limits are per server instance.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Staging / contract smoke bases (openapi-contract-smoke, synthetic checks)
# STAGING_BASE_URL=

# Playwright e2e: override base URL (default http://127.0.0.1:3000)
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
# Optional — reproducibility seed (propagated as x-playwright-e2e-seed header when set; also used by sweep logger sampling).
# E2E_RANDOM_SEED=
# Optional — enable visual regression snapshots (see playwright.config.ts and e2e/visual*.spec.ts)
# PLAYWRIGHT_VISUAL=1
# Optional — authenticated visual subset (e2e/visual.shell.spec.ts, e2e/v9-visual-optional.spec.ts)
# PLAYWRIGHT_VISUAL_AUTH=1
# Optional — single login in global setup + storageState for authenticated visuals (requires E2E_TEST_EMAIL / E2E_TEST_PASSWORD)
# PLAYWRIGHT_REUSE_AUTH_STORAGE=1
#
# Visual baselines (e2e/*-snapshots/*.png): on a new machine or after UI changes, record snapshots with:
#   npm run build && npm run test:e2e:visual:full:update
# Use test:e2e:visual:full:continue when the public phase fails but you still want the authenticated Playwright run.
# Optional — emit Playwright blob reports for merge-reports in CI (see playwright.config.ts)
# PLAYWRIGHT_BLOB_REPORT=1

# Optional — mobile projects (Pixel 5, iPad) for smoke subsets (playwright.config.ts)
# PLAYWRIGHT_MOBILE=1

# Optional — heap / memory budget hooks (e2e/memory-budget-smoke.spec.ts)
# PLAYWRIGHT_MEASURE_MEMORY=1

# Optional — nightly lighthouse smoke (scripts/lighthouse-smoke.mjs)
# RUN_LIGHTHOUSE_NIGHTLY=1

# Optional — multi-browser projects (Firefox/WebKit) for marketing + perf smokes (playwright.config.ts)
# PLAYWRIGHT_MULTI_BROWSER=1
# Optional — same multi-browser matrix for onboarding-deep specs (playwright.config.ts)
# PLAYWRIGHT_ONBOARDING_DEEP=1
# E2E_TEST_EMAIL=
# E2E_TEST_PASSWORD=

# Optional — jurisdiction / residency matrix hooks for compliance tests (src/lib/compliance/jurisdiction-region.contract.test.ts)
# ORG_DATA_REGION=

# Optional — post-run teardown webhook + DB hygiene (scripts/e2e-teardown.mjs; Playwright globalTeardown spawns npm run test:e2e:teardown)
# E2E_TEARDOWN=1
# E2E_TEARDOWN_WEBHOOK_URL=
# E2E_TEARDOWN_TABLES=
# E2E_TEARDOWN_RPC=
# E2E_TEARDOWN_STRICT=1

# Optional — OpenAPI live smoke (scripts/openapi-contract-smoke.mjs)
# OPENAPI_CONTRACT_STRICT=1
# OPENAPI_CONTRACT_BEARER=
# OPENAPI_SMOKE_PATHS=/,/api/health

# Optional — QA ultimate strictness (scripts/pipelines/pipeline-qa-ultimate.mjs)
# QA_ULTIMATE_STRICT=1

# Optional — SBOM diff ratchet vs baseline file (scripts/sbom-diff-stub.mjs)
# SBOM_DIFF_STRICT=1
# SBOM_BASELINE_PATH=cyclonedx-sbom.json
# Optional — onboarding calibration gate smoke (e2e/onboarding-calibration.spec.ts); requires blocking org.
# When enabled, the spec also loads /onboarding/calibration?step= to assert resume/clamped step UI.
# E2E_ONBOARDING_BLOCKING=1
# Optional — extra Playwright workspaces (e2e/refinement-optional-fixtures.spec.ts); skipped when unset
# E2E_ADVANCED_EMAIL=
# E2E_ADVANCED_PASSWORD=
# E2E_ASSURANCE_EMAIL=
# E2E_ASSURANCE_PASSWORD=
# E2E_CORE_NON_ADMIN_EMAIL=
# E2E_CORE_NON_ADMIN_PASSWORD=
# Optional — V5 relationship detail checks in e2e/v5-surfaces.spec.ts (must match contract keys in test org)
# E2E_ACCOUNT_KEY=
# E2E_COUNTERPARTY_KEY=

# Optional trial on new Stripe Checkout subscriptions (integer days). Unset = no trial in code.
# STRIPE_TRIAL_PERIOD_DAYS=14

# Optional — bypass first-run onboarding calibration redirect (proxy + OAuth callback). Route stays reachable.
# DISABLE_ONBOARDING_CALIBRATION_GATE=true

# Optional — service-role cron: expire stale blocking first-run questionnaires (GET /api/cron/v6/onboarding-calibration-stale).
# DISABLE_ONBOARDING_CALIBRATION_STALE_CRON=true
# ONBOARDING_CALIBRATION_STALE_CRON_DRY_RUN=1
# ONBOARDING_CALIBRATION_STALE_AFTER_DAYS=30
# Optional phase-2: also expire blocking "pending" when organizations.created_at is older than N days (unset = disabled).
# ONBOARDING_CALIBRATION_PENDING_STALE_AFTER_DAYS=
# Optional pacing between per-org writes (ms). Default 0.
# ONBOARDING_CALIBRATION_STALE_MS_BETWEEN_ORGS=0

# Optional Playwright: product settings questionnaire JSON export smoke (e2e/onboarding-calibration.spec.ts)
# E2E_ONBOARDING_EXPORT=1

# -----------------------------------------------------------------------------
# Optional — error tracking (Sentry)
# -----------------------------------------------------------------------------
# Create a project at https://sentry.io — use the same DSN for server and browser.
# Server: sentry.server.config.ts / sentry.edge.config.ts
# Client: src/instrumentation-client.ts (requires NEXT_PUBLIC_* for the bundle)
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# Optional: override release name in Sentry. On Vercel, `next.config.ts` also sets
# NEXT_PUBLIC_SENTRY_RELEASE from VERCEL_GIT_COMMIT_SHA (or GITHUB_SHA in CI) so browser and server events share a release without manual config.
# NEXT_PUBLIC_SENTRY_RELEASE=
# SENTRY_RELEASE=
# SENTRY_TRACES_SAMPLE_RATE=0
# SENTRY_PROFILES_SAMPLE_RATE=0
# Optional client overrides (defaults are production-safe when NODE_ENV=production):
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# NEXT_PUBLIC_SENTRY_REPLAY_SESSION_SAMPLE_RATE=0.05
# NEXT_PUBLIC_SENTRY_REPLAY_ON_ERROR_SAMPLE_RATE=1

# Optional — product surface diagnostics (server logs / Sentry breadcrumbs; see src/lib/product-surface)
# PRODUCT_SURFACE_DIAGNOSTICS=
# PRODUCT_SURFACE_SENTRY_DIAGNOSTICS=

# -----------------------------------------------------------------------------
# Optional — test-only fault injection (Vitest; see src/lib/dev-fault-injection.ts)
# -----------------------------------------------------------------------------
# TEST_FAULT_INJECTION=1

# -----------------------------------------------------------------------------
# Optional — QA maximal pipeline / Playwright fleet (.github/workflows/qa-code-maximal.yml)
# -----------------------------------------------------------------------------
# QA_MAXIMAL_SUBSET=1
# QA_MAXIMAL_SKIP_PLAYWRIGHT=1
# QA_MAXIMAL_PLAYWRIGHT_ONLY=1
# QA_MAXIMAL_INCLUDE_ULTIMATE=1
# QA_MAXIMAL_INCLUDE_POSTMERGE=1
# QA_MAXIMAL_DISCOVER_CHECK_UNION=1
# QA_MAXIMAL_DISCOVER_BATCH_TOTAL=8
# QA_MAXIMAL_DISCOVER_BATCH_INDEX=1
# QA_MAXIMAL_MULTI_BROWSER=1
# PLAYWRIGHT_MAXIMAL_CI=1
# PLAYWRIGHT_SHARD_INDEX=1
# PLAYWRIGHT_SHARD_TOTAL=1
# PLAYWRIGHT_TRACE_FAILURE_ONLY=1
# PLAYWRIGHT_TRACE_FULL=1
# PLAYWRIGHT_VIDEO=1
# PLAYWRIGHT_VISUAL_CONTINUE=1
# VITEST_COVERAGE_MAXIMAL=1
# Staging / synthetic legs (also referenced by qa-tier-manifest nightly tier)
# STAGING_BASE_URL=
# RLS_SMOKE_STRICT=1
# RUN_LIGHTHOUSE_NIGHTLY=1
# SYNTHETIC_STRICT=1
# SBOM_DIFF_STRICT=1
# COSIGN_PUBLIC_KEY=
# SLSA_VERIFY_STRICT=1
# SEMGREP_FULL=1
# SLO_BUDGETS_STRICT=1
# Optional — twelfth-expansion maximal ratchets (see src/lib/qa/maximal-twelfth-expansion-behavior.test.ts and scripts/check-*-ratchet.mjs)
# NATIVE_ASAN_STRICT=1
# QA_ARCHAEOLOGY_STRICT=1
# QA_DEPENDENCY_CYCLES_STRICT=1
# ADR_REQUIRED_STRICT=1
# CLA_DCO_POLICY_STRICT=1
# QA_COPYLEFT_STRICT=1
