# =============================================================================
# Contract Operations Tracker — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in real values.
#   cp .env.example .env.local
#
# NEXT_PUBLIC_ vars are embedded in the browser bundle — never put secrets there.
# All other vars are server-only.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
# Project Settings → API in the Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — NEVER prefix with NEXT_PUBLIC_
# Used for admin operations that bypass Row Level Security
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
# Developers → API keys in the Stripe dashboard
# Use test-mode keys (pk_test_ / sk_test_) during development
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# Developers → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------
# API Keys page in the Resend dashboard
RESEND_API_KEY=

# Verified sender address (use onboarding@resend.dev for sandbox testing)
EMAIL_FROM=

# -----------------------------------------------------------------------------
# AI / LLM extraction pipeline
# -----------------------------------------------------------------------------
# Provider API key for schema-constrained extraction (e.g. OpenAI)
OPENAI_API_KEY=

# Optional — override default gpt-4o-mini for extraction only
# OPENAI_EXTRACTION_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# Base URL of this app — used for absolute links in emails, redirects, Stripe, etc.
# Local: http://localhost:3000  Production: https://your-domain.com
# For local dev, keep this as localhost even if you also deploy to Vercel — server-side
# extraction uses the request Host header when possible to avoid calling production by mistake.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Optional — product behavior
# -----------------------------------------------------------------------------
# When true, creating/editing contracts, uploads, extraction, and field review
# require an org with stripe_subscription_id set (after successful checkout).
# Leave unset or false for local development without billing.
# REQUIRE_ACTIVE_SUBSCRIPTION=true

# When true, org admins can run “Load demo contracts” in Settings (sample data).
# ENABLE_DEMO_SEED=true

# Secret for GET /api/reminders/send (cron). Required in production for that route.
# CRON_SECRET=

# Optional trial on new Stripe Checkout subscriptions (integer days). Unset = no trial in code.
# STRIPE_TRIAL_PERIOD_DAYS=14

# -----------------------------------------------------------------------------
# Optional — error tracking (Sentry)
# -----------------------------------------------------------------------------
# Create a project at https://sentry.io and paste the DSN. Initializes via src/instrumentation.ts.
# @sentry/nextjs may require: npm install --legacy-peer-deps (Next.js 16 peer range lag).
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0
