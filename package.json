{
  "name": "oblixa",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "eslint src e2e playwright.config.ts vitest.config.ts next.config.ts --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "audit:moderate": "npm audit",
    "sbom": "npx --yes @cyclonedx/cyclonedx-npm@4.2.1 --output-file cyclonedx-sbom.json --package-lock-only --ignore-npm-errors",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "check:migrations": "node scripts/check-migrations.mjs",
    "check:api-route-tests": "node scripts/check-api-route-tests.mjs",
    "check:vercel-cron": "node scripts/check-vercel-cron-alignment.mjs",
    "check:cron-canary": "node scripts/cron-canary.mjs",
    "check:comprehensive-pass": "node scripts/comprehensive-pass.mjs",
    "preflight:release": "node scripts/release-preflight.mjs",
    "release:checklist": "node scripts/release-checklist.mjs",
    "verify": "npm run check:migrations && npm run check:api-route-tests && npm run check:vercel-cron && npm run lint && npm run typecheck && npm run test:coverage && npm run build"
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.4.0",
    "@sentry/nextjs": "^10.47.0",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.7.0",
    "mammoth": "^1.12.0",
    "next": "16.2.2",
    "next-themes": "^0.4.6",
    "openai": "^6.33.0",
    "pdf-parse": "^1.1.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.10.0",
    "stripe": "^22.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@next/bundle-analyzer": "16.2.2",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "@vitest/coverage-v8": "4.1.2",
    "vitest": "^4.1.2"
  }
}
