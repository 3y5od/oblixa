# Local-only development auth. Copy to .env.local, then fill Supabase keys from:
#   supabase status -o env

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

E2E_TEST_EMAIL=dev@oblixa.local
E2E_TEST_PASSWORD=dev-password-12345
# Optional: if present, `npm run seed:local-auth` also seeds this local login.
COMPREHENSIVE_PASS_EMAIL=
COMPREHENSIVE_PASS_PASSWORD=
COMPREHENSIVE_PASS_FULL_NAME=

# Optional local defaults.
REQUIRE_ACTIVE_SUBSCRIPTION=false
ENABLE_DEMO_SEED=true
