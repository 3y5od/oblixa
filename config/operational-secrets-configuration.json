{
  "schemaVersion": 1,
  "source": "code-owned-operational-secrets-configuration",
  "objectives": [
    {
      "id": "secret-location-boundaries",
      "ownerArea": "platform-security",
      "commands": [
        { "command": "check:operational-secrets-configuration", "ciRequired": true, "covers": ["aggregate_registry", "artifact_drift", "allowlist_expiry"] },
        { "command": "check:static-secret-safety", "ciRequired": true, "covers": ["source_docs_artifacts_secret_shapes"] },
        { "command": "check:tracked-secrets-hygiene", "ciRequired": true, "covers": ["env_gitignore", "tracked_key_material"] },
        { "command": "check:test-fixture-secrets", "ciRequired": true, "covers": ["test_fixture_secret_shapes"] },
        { "command": "check:ci-artifact-secret-leakage", "ciRequired": true, "covers": ["artifact_path_secret_exclusions"] },
        { "command": "check:gitleaks-allowlist", "ciRequired": true, "covers": ["secret_scan_allowlist_scope"] }
      ],
      "artifacts": ["artifacts/operational-secrets-configuration.json"]
    },
    {
      "id": "public-client-secret-leakage",
      "ownerArea": "platform-security",
      "commands": [
        { "command": "check:next-public-surface", "ciRequired": true, "covers": ["next_public_env_allowlist"] },
        { "command": "check:client-bundle-secret-leakage", "ciRequired": true, "covers": ["client_reachable_env_graph"] },
        { "command": "check:env-contract-hygiene", "ciRequired": true, "covers": ["public_secret_key_name_detection"] },
        { "command": "check:operational-secrets-configuration", "ciRequired": true, "covers": ["public_env_allowlist_parity"] }
      ]
    },
    {
      "id": "token-quality",
      "ownerArea": "platform-security",
      "commands": [
        { "command": "check:secrets-env-token-quality", "ciRequired": true, "covers": ["env_placeholder_quality", "token_secret_markers"] },
        { "command": "check:token-security-quality", "ciRequired": true, "covers": ["token_expiry_status_compare"] },
        { "command": "check:security-env-contract", "ciRequired": true, "covers": ["env_contract_required_keys"] },
        { "command": "check:release-security-required-env", "ciRequired": true, "covers": ["provider_prefixes", "previous_secret_expiry"] }
      ]
    },
    {
      "id": "secret-rotation-readiness",
      "ownerArea": "platform-security",
      "commands": [
        { "command": "check:secret-rotation-readiness", "ciRequired": true, "covers": ["rotation_signal_scan"] },
        { "command": "tools:reencrypt-integration-tokens", "ciRequired": false, "covers": ["dry_run_reencryption_tooling"] },
        { "command": "check:operational-secrets-configuration", "ciRequired": true, "covers": ["rotation_contract_registry"] }
      ]
    }
  ],
  "secretBoundaries": [
    {
      "id": "tracked-source-boundary",
      "surface": "tracked source and config",
      "command": "check:tracked-secrets-hygiene",
      "policy": "tracked env files and key material are denied except .env.example templates"
    },
    {
      "id": "reviewable-text-boundary",
      "surface": "tests, fixtures, scripts, docs, artifacts, and workflows",
      "command": "check:static-secret-safety",
      "policy": "secret-shaped placeholders require owned expiring inline marker classification"
    },
    {
      "id": "fixture-boundary",
      "surface": "test fixtures and evidence fixtures",
      "command": "check:test-fixture-secrets",
      "policy": "fake provider tokens require the security:test-fixture-secret-placeholder marker"
    },
    {
      "id": "ci-artifact-boundary",
      "surface": "workflow upload and download artifacts",
      "command": "check:ci-artifact-secret-leakage",
      "policy": "artifact paths must avoid hidden files, credentials, auth state, and broad workspace downloads"
    },
    {
      "id": "client-bundle-boundary",
      "surface": "client reachable module graph",
      "command": "check:client-bundle-secret-leakage",
      "policy": "client bundles may only read public env keys and must not import server secret modules"
    }
  ],
  "allowlists": [
    {
      "path": "scripts/static-secret-placeholder-allowlist.json",
      "schemaVersion": 1,
      "requiredEntryFields": ["marker", "owner", "reason", "expiresOn", "reviewedOn", "compensatingTest"]
    }
  ],
  "publicEnvAllowlist": [
    "NEXT_PUBLIC_APP_URL",
    "NEXT_PUBLIC_OBLIXA_CLIENT_SWEEP_BREADCRUMB",
    "NEXT_PUBLIC_PRODUCT_SURFACE_DIAGNOSTICS",
    "NEXT_PUBLIC_PRODUCT_SURFACE_SENTRY_DIAGNOSTICS",
    "NEXT_PUBLIC_INLINE_QUEUE_ACTIONS",
    "NEXT_PUBLIC_SENTRY_DSN",
    "NEXT_PUBLIC_SENTRY_RELEASE",
    "NEXT_PUBLIC_SENTRY_REPLAY_ON_ERROR_SAMPLE_RATE",
    "NEXT_PUBLIC_SENTRY_REPLAY_SESSION_SAMPLE_RATE",
    "NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE",
    "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY",
    "NEXT_PUBLIC_SUPPORT_DIAGNOSTICS",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_V9_INLINE_QUEUE_ACTIONS",
    "NEXT_PUBLIC_V10_SUPPORT_DIAGNOSTICS"
  ],
  "rotationContracts": [
    {
      "id": "cron-secret",
      "strategy": "current_previous_expiring",
      "envKeys": ["CRON_SECRET", "CRON_SECRET_PREVIOUS", "CRON_SECRET_PREVIOUS_EXPIRES_AT"],
      "implementationFiles": ["src/lib/security/cron-auth.ts", "src/lib/security/cron-route-gate.ts"],
      "testFiles": ["src/lib/security/cron-auth.test.ts", "src/lib/security/cron-route-gate.test.ts"]
    },
    {
      "id": "internal-hmac",
      "strategy": "current_previous_expiring",
      "envKeys": ["OBLIXA_INTERNAL_HMAC_SECRET", "OBLIXA_INTERNAL_HMAC_PREVIOUS_SECRET", "OBLIXA_INTERNAL_HMAC_PREVIOUS_EXPIRES_AT"],
      "implementationFiles": ["src/lib/security/internal-hmac.ts", "src/app/api/extract/run/route.ts"],
      "testFiles": ["src/lib/security/internal-hmac.test.ts", "src/app/api/extract/run/route.test.ts"]
    },
    {
      "id": "stripe-webhook-secret",
      "strategy": "current_previous_expiring",
      "envKeys": ["STRIPE_WEBHOOK_SECRET", "STRIPE_WEBHOOK_SECRET_PREVIOUS", "STRIPE_WEBHOOK_SECRET_PREVIOUS_EXPIRES_AT"],
      "implementationFiles": ["src/app/api/stripe/webhook/route.ts"],
      "testFiles": ["src/app/api/stripe/webhook/route.test.ts"]
    },
    {
      "id": "external-submit-ticket-secret",
      "strategy": "current_previous_expiring",
      "envKeys": ["EXTERNAL_ACTION_SUBMIT_TICKET_SECRET", "EXTERNAL_ACTION_SUBMIT_TICKET_SECRET_PREVIOUS", "EXTERNAL_ACTION_SUBMIT_TICKET_SECRET_PREVIOUS_EXPIRES_AT"],
      "implementationFiles": ["src/lib/decision-intelligence/api.ts"],
      "testFiles": ["src/lib/decision-intelligence/api.external.test.ts"]
    },
    {
      "id": "inbound-automation-tokens",
      "strategy": "route_specific_current_previous_expiring",
      "envKeys": [
        "INBOUND_AUTOMATION_TOKEN",
        "INBOUND_AUTOMATION_TOKEN_PREVIOUS",
        "INBOUND_AUTOMATION_TOKEN_PREVIOUS_EXPIRES_AT",
        "INBOUND_EMAIL_AUTOMATION_TOKEN",
        "INBOUND_EMAIL_AUTOMATION_TOKEN_PREVIOUS",
        "INBOUND_EMAIL_AUTOMATION_TOKEN_PREVIOUS_EXPIRES_AT",
        "INBOUND_SLACK_AUTOMATION_TOKEN",
        "INBOUND_SLACK_AUTOMATION_TOKEN_PREVIOUS",
        "INBOUND_SLACK_AUTOMATION_TOKEN_PREVIOUS_EXPIRES_AT",
        "INBOUND_INTEGRATIONS_CALLBACK_TOKEN",
        "INBOUND_INTEGRATIONS_CALLBACK_TOKEN_PREVIOUS",
        "INBOUND_INTEGRATIONS_CALLBACK_TOKEN_PREVIOUS_EXPIRES_AT"
      ],
      "implementationFiles": ["src/lib/security/inbound-automation-token.ts"],
      "testFiles": ["src/lib/security/inbound-automation-token.test.ts"]
    },
    {
      "id": "integration-token-encryption",
      "strategy": "versioned_key_id",
      "envKeys": ["INTEGRATION_TOKEN_ENCRYPTION_KEY", "OBLIXA_ACTIVE_TOKEN_ENCRYPTION_KEY_ID", "OBLIXA_TOKEN_ENCRYPTION_KEY_DEFAULT"],
      "implementationFiles": ["src/lib/security/token-crypto.ts", "scripts/reencrypt-integration-tokens.mjs"],
      "testFiles": ["src/lib/security/token-crypto.test.ts", "scripts/reencrypt-integration-tokens.test.mjs"]
    }
  ],
  "sourceMarkers": [
    {
      "path": ".gitignore",
      "markers": [".env*", "!.env.example", "!.env.local.example", "*.pem"]
    },
    {
      "path": "scripts/static-secret-placeholder-allowlist.json",
      "markers": ["security:test-fixture-secret-placeholder", "\"expiresOn\"", "\"compensatingTest\""]
    },
    {
      "path": "scripts/check-next-public-surface.mjs",
      "markers": ["PUBLIC_ENV_ALLOWLIST", "FORBIDDEN_PUBLIC_ENV_TOKENS", "PUBLIC_DIAGNOSTIC_ALLOWED_FILES"]
    },
    {
      "path": "scripts/check-client-bundle-secret-leakage.mjs",
      "markers": ["analyzeClientBundleSecretLeakage", "server_env_in_client_bundle", "sensitive_next_public_env"]
    },
    {
      "path": "scripts/check-static-secret-safety.mjs",
      "markers": ["analyzeStaticSecretSafety", "SECRET_PATTERNS", "static-secret-placeholder-allowlist.json"]
    },
    {
      "path": "src/lib/security/rotating-secret.ts",
      "markers": ["validatePreviousSecretExpiry", "rotatingSecretCandidates", "previous_secret_expired"]
    },
    {
      "path": "src/app/api/stripe/webhook/route.ts",
      "markers": ["STRIPE_WEBHOOK_SECRET_PREVIOUS", "STRIPE_WEBHOOK_SECRET_PREVIOUS_EXPIRES_AT", "rotatingSecretCandidates"]
    },
    {
      "path": "src/lib/decision-intelligence/api.ts",
      "markers": ["EXTERNAL_ACTION_SUBMIT_TICKET_SECRET_PREVIOUS", "EXTERNAL_ACTION_SUBMIT_TICKET_SECRET_PREVIOUS_EXPIRES_AT", "rotatingSecretCandidates"]
    }
  ],
  "testMarkers": [
    {
      "path": "src/lib/security/rotating-secret.test.ts",
      "markers": ["builds current and previous secret candidates only when previous metadata is valid"]
    },
    {
      "path": "src/app/api/stripe/webhook/route.test.ts",
      "markers": [
        "accepts a valid previous Stripe webhook secret during bounded rotation",
        "rejects an expired previous Stripe webhook secret during rotation"
      ]
    },
    {
      "path": "src/lib/decision-intelligence/api.external.test.ts",
      "markers": [
        "accepts previous submit-ticket secret during bounded rotation",
        "rejects expired previous submit-ticket secret during rotation"
      ]
    },
    {
      "path": "src/lib/security/inbound-automation-token.test.ts",
      "markers": ["accepts previous route-specific and shared tokens during rotation", "rejects expired previous inbound tokens during rotation"]
    }
  ]
}
