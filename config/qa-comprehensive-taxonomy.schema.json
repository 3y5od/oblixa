{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oblixa.local/config/qa-comprehensive-taxonomy.schema.json",
  "title": "QA comprehensive taxonomy",
  "type": "object",
  "required": ["catalogVersion", "taxonomyVersion", "items"],
  "properties": {
    "catalogVersion": { "type": "integer", "minimum": 1 },
    "taxonomyVersion": { "type": "integer", "minimum": 1 },
    "aliases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "until": { "type": "string" }
        }
      }
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "section", "title", "priorityBand", "applicability", "source", "bindings"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "section": { "type": "string" },
          "title": { "type": "string" },
          "priorityBand": { "type": "string", "enum": ["P0", "P1", "P2", "P3"] },
          "applicability": { "type": "string", "enum": ["always", "product_absent", "env_strict_only"] },
          "source": {
            "type": "string",
            "enum": ["assistant_list_1", "assistant_list_2", "assistant_list_3", "deduped"]
          },
          "riskScore": { "type": "number", "minimum": 0, "maximum": 10 },
          "dependsOn": { "type": "array", "items": { "type": "string" } },
          "executionHint": { "type": "string" },
          "bindings": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["kind", "ref"],
              "properties": {
                "kind": {
                  "type": "string",
                  "enum": [
                    "npmScript",
                    "workflow",
                    "reusableWorkflow",
                    "fileGlob",
                    "vitestEntry",
                    "e2eSpec",
                    "artifactPath",
                    "sarifPolicy",
                    "waiver"
                  ]
                },
                "ref": { "type": "string", "minLength": 1 },
                "notes": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
