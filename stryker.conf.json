{
  "$schema": "https://json.schemastore.org/stryker-config.json",
  "packageManager": "npm",
  "testRunner": "vitest",
  "coverageAnalysis": "perTest",
  "mutate": ["src/lib/compliance/**/*.ts", "!**/*.test.ts"],
  "thresholds": { "high": 80, "low": 50, "break": 40 },
  "tempDirName": "stryker-tmp",
  "timeoutMS": 120000,
  "concurrency": 4,
  "ignorePatterns": [".github/**", "e2e/**", "artifacts/**"],
  "comment": "Enable in nightly with RUN_STRYKER=1 when ready to ratchet mutation targets."
}
